# Copy to .env and replace every value before running Docker Compose.
DB_USER=omni
DB_PASSWORD=replace-with-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
# Optional read replica (defaults to primary when unset — single DB is fine)
# DB_SLAVE_HOST=
# DB_SLAVE_PORT=3306
# DB_SLAVE_NAME=omni
# DB_SLAVE_USER=
# DB_SLAVE_PASSWORD=
REDIS_PASSWORD=replace-with-strong-redis-password

# Both secrets must be random and at least 32 bytes.
OMNI_JWT_SECRET=replace-with-random-jwt-secret-at-least-32-bytes
OMNI_SIGN_SECRET=replace-with-random-sign-secret-at-least-32-bytes
# Used only to replace the seeded admin/admin123 password on first production startup.
OMNI_ADMIN_INITIAL_PASSWORD=replace-with-strong-initial-admin-password
# Production CORS Origins (comma-separated, include scheme). Must match the browser URL.
# OMNI_CORS_ORIGINS=http://omni-scaffolding.example.com,https://omni-scaffolding.example.com

# Login security (optional overrides; see docs/ADOPT.md)
# OMNI_SECURITY_CAPTCHA_ENABLED=true
# OMNI_SECURITY_LOGIN_LOCK_ENABLED=true
# OMNI_SECURITY_LOGIN_LOCK_MAX_FAILURES=5
# OMNI_SECURITY_LOGIN_LOCK_SECONDS=900
# OMNI_SECURITY_PWD_MIN_LENGTH=8
# OMNI_SECURITY_PWD_REQUIRE_UPPER=true
# OMNI_SECURITY_PWD_REQUIRE_LOWER=true
# OMNI_SECURITY_PWD_REQUIRE_DIGIT=true

# File storage: local (default) | minio | oss
# OMNI_FILE_STORAGE_TYPE=local
# OMNI_UPLOAD_DIR=./data/uploads
# OMNI_FILE_SIGN_SECRET=replace-with-file-sign-secret-or-reuse-jwt
# MinIO (when OMNI_FILE_STORAGE_TYPE=minio)
# OMNI_MINIO_ENDPOINT=http://127.0.0.1:9000
# OMNI_MINIO_ACCESS_KEY=minioadmin
# OMNI_MINIO_SECRET_KEY=minioadmin
# OMNI_MINIO_BUCKET=omni
# Aliyun OSS (when OMNI_FILE_STORAGE_TYPE=oss and OMNI_OSS_PROVIDER=aliyun)
# OMNI_OSS_PROVIDER=aliyun
# OMNI_OSS_ALIYUN_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OMNI_OSS_ALIYUN_ACCESS_KEY_ID=
# OMNI_OSS_ALIYUN_ACCESS_KEY_SECRET=
# OMNI_OSS_ALIYUN_BUCKET=

# Druid is disabled in production by default.
DRUID_ENABLED=false
DRUID_ALLOW=127.0.0.1
DRUID_USERNAME=druid
DRUID_PASSWORD=replace-before-enabling-druid
