<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.omni.scaffolding.modules.system.mapper.SysOperLogQueryMapper">

    <sql id="OperLogSearchWhere">
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="module != null and module != ''">
                AND module LIKE CONCAT('%', #{module}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </sql>

    <select id="count" resultType="long">
        SELECT COUNT(1)
        FROM sys_oper_log
        <include refid="OperLogSearchWhere"/>
    </select>

    <select id="search" resultType="com.omni.scaffolding.modules.system.dto.OperLogView">
        SELECT id,
               user_id AS userId,
               username,
               module,
               action,
               method,
               request_uri AS requestUri,
               request_method AS requestMethod,
               ip,
               status,
               error_msg AS errorMsg,
               cost_ms AS costMs,
               params,
               trace_id AS traceId,
               oper_time AS operTime
        FROM sys_oper_log
        <include refid="OperLogSearchWhere"/>
        ORDER BY oper_time DESC, id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <delete id="deleteById">
        DELETE FROM sys_oper_log WHERE id = #{id}
    </delete>
</mapper>
