<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.omni.scaffolding.modules.system.mapper.SysLoginLogQueryMapper">

    <sql id="LoginLogSearchWhere">
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="ip != null and ip != ''">
                AND ip LIKE CONCAT('%', #{ip}, '%')
            </if>
        </where>
    </sql>

    <select id="count" resultType="long">
        SELECT COUNT(1)
        FROM sys_login_log
        <include refid="LoginLogSearchWhere"/>
    </select>

    <select id="search" resultType="com.omni.scaffolding.modules.system.dto.log.LoginLogView">
        SELECT id,
               user_id AS userId,
               username,
               ip,
               user_agent AS userAgent,
               status,
               message,
               trace_id AS traceId,
               login_time AS loginTime
        FROM sys_login_log
        <include refid="LoginLogSearchWhere"/>
        ORDER BY login_time DESC, id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <delete id="deleteById">
        DELETE FROM sys_login_log WHERE id = #{id}
    </delete>
</mapper>
