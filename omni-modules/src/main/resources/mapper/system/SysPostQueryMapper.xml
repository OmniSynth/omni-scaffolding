<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.omni.scaffolding.modules.system.mapper.SysPostQueryMapper">

    <sql id="PostSearchWhere">
        WHERE deleted = 0
        <if test="keyword != null and keyword != ''">
            AND (code LIKE CONCAT('%', #{keyword}, '%')
                OR name LIKE CONCAT('%', #{keyword}, '%'))
        </if>
    </sql>

    <select id="countPosts" resultType="long">
        SELECT COUNT(1)
        FROM sys_post
        <include refid="PostSearchWhere"/>
    </select>

    <select id="listPosts" resultType="com.omni.scaffolding.modules.system.dto.post.PostView">
        SELECT id, code, name, sort, status
        FROM sys_post
        <include refid="PostSearchWhere"/>
        ORDER BY sort, id
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="findById" resultType="com.omni.scaffolding.modules.system.dto.post.PostView">
        SELECT id, code, name, sort, status
        FROM sys_post
        WHERE id = #{postId}
          AND deleted = 0
    </select>

    <select id="countUsersByPostId" resultType="long">
        SELECT COUNT(1) FROM sys_user_post WHERE post_id = #{postId}
    </select>
</mapper>
